# OpenAI-compatible API
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Optional search API used by the search-based reasoning pipeline
SERPER_API_KEY=your_serper_api_key_here

# Generation
TEMPERATURE=0.0
TOP_P=1.0
MAX_TOKENS=1024
TIMEOUT=120
RETRY_TIMES=2

# Multi-round reasoning
MAX_SEARCH_ROUNDS=5
SALIENCY_TOP_K=8
MAX_WORKERS=4

# Candidate proposal and filtering
MAX_BOXES=20
MIN_BOX_AREA_RATIO=0.01
MAX_BOX_AREA_RATIO=0.95
NMS_IOU_THRESHOLD=0.65

# Search settings
SEARCH_RESULTS_PER_QUERY=5
SEARCH_MAX_QUERIES=3

# Data and outputs
# Default Hugging Face package layout under Pixel-Searcher/:
DATASET_ROOT=./dataset
OUTPUT_ROOT=./outputs

# Default task files:
# --grounding-jsonl ./dataset/data/search_grounding.jsonl
# --choice-jsonl ./dataset/data/search_vqa.jsonl

SAVE_RAW=true
